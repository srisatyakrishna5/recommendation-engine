{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit Prototype",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "app.py"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "justMyCode": true
    }
  ]
}
