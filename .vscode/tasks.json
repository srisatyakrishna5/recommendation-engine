{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Python dependencies",
      "type": "shell",
      "command": ".venv\\Scripts\\python",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "problemMatcher": []
    },
    {
      "label": "Run Streamlit Prototype",
      "type": "shell",
      "command": ".venv\\Scripts\\python",
      "args": [
        "-m",
        "streamlit",
        "run",
        "app.py"
      ],
      "options": {
        "env": {
          "PYTHONPATH": "${workspaceFolder}/src"
        }
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
